# Copy to .env (gitignored, loaded automatically). Never commit real secrets.

# --- Auth ---
# Used by BOTH the synthetic-data feature (raw Anthropic API) and the segmentation agent.
ANTHROPIC_API_KEY=sk-ant-...

# --- Survey database (research) ---
SURVEY_MONGO_URL=mongodb://user:password@host:port/research
SURVEY_MONGO_DB=research

# --- Synthetic-data feature ---
ANTHROPIC_MODEL=claude-opus-4-7
MAX_GENERATE_RESPONDENTS=50
GENERATE_WORKERS=5
PREVIEW_SAMPLE=10
PREVIEW_WORKERS=10

# --- Segmentation feature (Agent SDK) ---
SEGMENTATION_MODEL=claude-opus-4-8
FALLBACK_MODEL=claude-opus-4-7
MAX_TURNS=120
MAX_BUDGET_USD=8
RUN_TIMEOUT_SECONDS=1800
MAX_CONCURRENT_RUNS=2
MAX_UPLOAD_MB=50
SEGMENTATION_ROW_CAP=8000

# --- Server ---
# Must match the nginx upstream (proxy_pass http://127.0.0.1:PORT_NUMBER).
PORT_NUMBER=9260
DEV_MODE=true
RUNS_DIR=runs
UPLOADS_DIR=uploads

# --- MCP endpoint (/mcp/) ---
# Shared secret for Claude clients; leave empty ONLY for localhost dev (open endpoint).
MCP_AUTH_TOKEN=
# Public origin (https://...) used in MCP download links, e.g. the tunnel/proxy host.
PUBLIC_BASE_URL=
