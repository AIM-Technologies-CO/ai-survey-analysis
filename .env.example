# Copy to app/.env (loaded automatically by the server) or export these in your shell.

# Required: Anthropic API key for the suggest/answer features.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (default below).
ANTHROPIC_MODEL=claude-opus-4-7

# Required: MongoDB connection string for the research DB.
SURVEY_MONGO_URL=mongodb://user:password@host:port/research
SURVEY_MONGO_DB=research
